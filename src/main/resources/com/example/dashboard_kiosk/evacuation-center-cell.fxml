<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
   One sidebar card representing a single evacuation center.
   Layout (top to bottom):
     · title row     — center name + status pill
     · meta row      — ID • barangay
     · supplies      — wrapping flow of supply tags
   Card styling lives in style.css under .center-card / .center-card-selected.
-->
<VBox fx:id="cardRoot"
      spacing="10.0"
      styleClass="center-card"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.dashboard_kiosk.EvacuationCenterCellController">
    <padding>
        <Insets bottom="14.0" left="16.0" right="16.0" top="14.0" />
    </padding>
    <children>

        <!-- TITLE ROW: name on the left, status pill on the right -->
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <Label fx:id="lblTitle"
                       styleClass="center-card-title"
                       text="Argao Command Center"
                       wrapText="true"
                       HBox.hgrow="ALWAYS" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblStatus"
                       styleClass="status-tag, status-tag-open"
                       text="Open" />
            </children>
        </HBox>

        <!-- META ROW: short ID and address line -->
        <Label fx:id="lblMeta"
               styleClass="center-card-meta"
               text="EC-01 · Brgy. Poblacion" />

        <!-- SUPPLY TAGS: wrap to next line if they overflow -->
        <FlowPane fx:id="suppliesFlow"
                  hgap="6.0"
                  vgap="6.0"
                  styleClass="supplies-flow" />
    </children>
</VBox>
