<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.web.WebView?>

<AnchorPane fx:id="mainRoot" prefHeight="800.0" prefWidth="1280.0" styleClass="root-pane" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.dashboard_kiosk.KioskDashboardController">
    <children>
        <!--
           Outer HBox is now anchored to all four edges so the dashboard fills
           the whole screen dynamically when maximized.
         -->
        <HBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>

                <!-- SIDEBAR
                     Removed preferred/fixed heights so it stretches natively.
                -->
                <VBox prefWidth="250.0" styleClass="sidebar" HBox.hgrow="NEVER">
                    <children>
                        <!-- Logo Section -->
                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="logo-container">
                            <padding>
                                <Insets bottom="32.0" left="24.0" right="24.0" top="32.0" />
                            </padding>
                            <children>
                                <StackPane styleClass="logo-icon-bg">
                                    <children>
                                        <Label styleClass="logo-icon" text="CG" />
                                    </children>
                                </StackPane>
                                <Label styleClass="logo-text" text="CivicGuard" />
                            </children>
                        </HBox>

                        <!-- Nav Menu -->
                        <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                            <padding>
                                <Insets left="16.0" right="16.0" top="16.0" />
                            </padding>
                            <children>
                                <Label styleClass="nav-header" text="MAIN MENU" />

                                <!-- Note: BrgyDashboardController handles navigation logic -->
                                <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" styleClass="nav-item" text="Admin Portal" />
                                <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" styleClass="nav-item" text="LGU Portal" />
                                <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" styleClass="nav-item, nav-active" text="Evacuee Portal" />
                            </children>
                        </VBox>

                        <Region VBox.vgrow="ALWAYS" />

                        <!-- Profile / Footer -->
                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="profile-section">
                            <padding>
                                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                            </padding>
                            <children>
                                <Circle radius="18.0" styleClass="avatar-circle" />
                                <VBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label styleClass="profile-name" text="Public View" />
                                        <Label styleClass="profile-role" text="Read-only access" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- MAIN LAYOUT -->
                <VBox HBox.hgrow="ALWAYS">
                    <children>
                        <!-- TOP HEADER -->
                        <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="20.0" styleClass="header-bar">
                            <padding>
                                <Insets left="32.0" right="32.0" />
                            </padding>
                            <children>
                                <VBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label styleClass="header-title" text="Evacuation Status" />
                                        <Label styleClass="header-subtitle" text="Real-time capacity and updates" />
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <HBox alignment="CENTER" spacing="16.0">
                                    <children>
                                        <HBox alignment="CENTER" spacing="8.0" styleClass="status-pill">
                                            <padding>
                                                <Insets left="12.0" right="12.0" />
                                            </padding>
                                            <children>
                                                <Circle fill="#10b981" radius="4.0" styleClass="pulse-circle" />
                                                <Label styleClass="status-text" text="Live Updates" />
                                            </children>
                                        </HBox>
                                        <Button mnemonicParsing="false" styleClass="btn-refresh" text="↻" />
                                    </children>
                                </HBox>
                            </children>
                        </HBox>

                        <!-- CONTENT AREA -->
                        <!-- Instead of fixed 695.0 height, use VBox.vgrow="ALWAYS" -->
                        <VBox spacing="24.0" styleClass="content-scroll" VBox.vgrow="ALWAYS">
                            <padding>
                                <Insets bottom="32.0" left="32.0" right="32.0" top="24.0" />
                            </padding>
                            <children>

                                <!-- Top row: Map (left) + Alert Info (right) -->
                                <HBox spacing="24.0" VBox.vgrow="ALWAYS">
                                    <children>
                                        <!-- Map Panel -->
                                        <VBox styleClass="card-container" HBox.hgrow="ALWAYS">
                                            <children>
                                                <HBox alignment="CENTER_LEFT" styleClass="card-header">
                                                    <padding>
                                                        <Insets bottom="16.0" left="20.0" right="20.0" top="20.0" />
                                                    </padding>
                                                    <children>
                                                        <Label styleClass="card-title" text="Map Overview" />
                                                    </children>
                                                </HBox>
                                                <!-- Overlay pane so detail modal can float on top of map -->
                                                <AnchorPane fx:id="mapOverlayPane" VBox.vgrow="ALWAYS">
                                                    <children>
                                                        <WebView fx:id="webViewMiniMap" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
                                                    </children>
                                                </AnchorPane>
                                            </children>
                                        </VBox>

                                        <!-- Urgent Alerts & General Info Panel -->
                                        <VBox prefWidth="350.0" spacing="16.0" styleClass="card-container" HBox.hgrow="NEVER">
                                            <children>
                                                <HBox alignment="CENTER_LEFT" styleClass="card-header">
                                                    <padding>
                                                        <Insets bottom="16.0" left="20.0" right="20.0" top="20.0" />
                                                    </padding>
                                                    <children>
                                                        <Label styleClass="card-title" text="Emergency Alerts" />
                                                    </children>
                                                </HBox>
                                                <VBox spacing="12.0">
                                                    <padding>
                                                        <Insets bottom="20.0" left="20.0" right="20.0" />
                                                    </padding>
                                                    <children>
                                                        <!-- Example Alert -->
                                                        <VBox styleClass="alert-item, alert-item-critical">
                                                            <children>
                                                                <Label styleClass="alert-title" text="Heavy Rainfall Warning" />
                                                                <Label styleClass="alert-location" text="Cebu City &amp; Surrounding areas" />
                                                                <Label styleClass="alert-qty" text="Evacuate if in low-lying areas" />
                                                            </children>
                                                        </VBox>
                                                        <!-- Additional static info can go here -->
                                                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 13;" text="Call 911 for life-threatening emergencies. Stay tuned to local radio." wrapText="true" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <!-- Bottom section: Evacuation Centers List -->
                                <VBox styleClass="card-container" VBox.vgrow="ALWAYS">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="card-header">
                                            <padding>
                                                <Insets bottom="16.0" left="20.0" right="20.0" top="20.0" />
                                            </padding>
                                            <children>
                                                <Label styleClass="card-title" text="Evacuation Centers Status" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <!-- If it's a read-only kiosk, hide the "New Request" button,
                                                     or re-purpose it for "Refresh" / "View All" -->
                                            </children>
                                        </HBox>

                                        <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="table-controls">
                                            <padding>
                                                <Insets bottom="16.0" left="20.0" right="20.0" />
                                            </padding>
                                            <children>
                                                <TextField fx:id="searchField1" prefHeight="36.0" prefWidth="250.0" promptText="Search center or location..." styleClass="search-field" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <HBox styleClass="segmented-control">
                                                    <children>
                                                        <Button fx:id="filterAll1" mnemonicParsing="false" styleClass="segment, segment-first, segment-active" text="All" />
                                                        <Button fx:id="filterOpen1" mnemonicParsing="false" styleClass="segment" text="Open" />
                                                        <Button fx:id="filterFull1" mnemonicParsing="false" styleClass="segment, segment-last" text="Full" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </HBox>

                                        <TableView fx:id="mainTable1" prefHeight="250.0" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colId1" prefWidth="180.0" text="CENTER NAME" />
                                                <TableColumn fx:id="colName1" prefWidth="300.0" text="LOCATION / ADDRESS" />
                                                <TableColumn fx:id="colCenter1" prefWidth="120.0" text="STATUS" />
                                                <TableColumn fx:id="colStatus1" prefWidth="120.0" text="ACTION" />
                                            </columns>
                                            <columnResizePolicy>
                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                            </columnResizePolicy>
                                        </TableView>
                                    </children>
                                </VBox>

                            </children>
                        </VBox>
                    </children>
                </VBox>

            </children>
        </HBox>
    </children>
</AnchorPane>
