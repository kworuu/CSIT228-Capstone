<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.web.WebView?>

<!--
    BrgyUser.fxml — Public-facing Kiosk / Barangay Dashboard (Refactored v2)
    ──────────────────────────────────────────────────────────────────────────
    Key changes from v1:
      • EventCell (fx:include) is now a DIRECT CHILD of the root AnchorPane,
        anchored top/right/bottom. This makes it truly overlay everything —
        the header bar, the search field, and the table — not just the map.
      • The ☰ hamburger button has been moved into the top header bar,
        placed to the right of the "Live" pill and left of the login buttons.
      • The StackPane inside the map card is now a clean, single-child
        container holding only the map WebView (no floating buttons).
      • EventCellController.initialize() translates the panel off-screen by
        its own width (300 px), so it is invisible until toggled.
    ──────────────────────────────────────────────────────────────────────────
-->

<AnchorPane fx:id="mainRoot" prefHeight="800.0" prefWidth="1280.0" styleClass="root-pane" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.dashboard_kiosk.KioskDashboardController">
    <children>

        <!-- ══════════════════════════════════════════════════════════════
             MAIN LAYOUT  —  Sidebar + Content column
             This HBox fills the entire root; EventCell overlays it.
             ══════════════════════════════════════════════════════════════ -->
        <HBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>

                <!-- ── SIDEBAR ──────────────────────────────────────────── -->
                <VBox prefWidth="248.0" styleClass="sidebar" HBox.hgrow="NEVER">
                    <children>

                        <!-- Logotype -->
                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="logo-container">
                            <padding>
                                <Insets bottom="28.0" left="22.0" right="22.0" top="28.0" />
                            </padding>
                            <children>
                                <StackPane styleClass="logo-icon-bg">
                                    <children>
                                        <Label styleClass="logo-icon" text="CG" />
                                    </children>
                                </StackPane>
                                <Label styleClass="logo-text" text="CivicGuard" />
                            </children>
                        </HBox>

                        <!-- Navigation -->
                        <VBox spacing="4.0" VBox.vgrow="ALWAYS">
                            <padding>
                                <Insets left="14.0" right="14.0" top="8.0" />
                            </padding>
                            <children>
                                <Label styleClass="nav-header" text="PORTAL" />
                                <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" styleClass="nav-item, nav-active" text="Evacuee Portal" />
                            </children>
                        </VBox>

                        <Region VBox.vgrow="ALWAYS" />

                        <!-- Profile footer -->
                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="profile-section">
                            <padding>
                                <Insets bottom="22.0" left="22.0" right="22.0" top="22.0" />
                            </padding>
                            <children>
                                <Circle radius="17.0" styleClass="avatar-circle" />
                                <VBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label styleClass="profile-name" text="Public View" />
                                        <Label styleClass="profile-role" text="Read-only access" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                    </children>
                </VBox>
                <!-- end sidebar -->

                <!-- ── MAIN CONTENT ─────────────────────────────────────── -->
                <VBox HBox.hgrow="ALWAYS">
                    <children>

                        <!-- ── TOP HEADER BAR ────────────────────────────── -->
                        <!--
                            The ☰ hamburger now lives here, between the Live pill
                            and the login buttons. This is the natural home for a
                            global panel toggle and keeps the map card clean.
                        -->
                        <HBox alignment="CENTER_LEFT" prefHeight="72.0" spacing="12.0" styleClass="header-bar">
                            <padding>
                                <Insets left="30.0" right="30.0" />
                            </padding>
                            <children>

                                <!-- Page title -->
                                <VBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label styleClass="header-title" text="Evacuation Status" />
                                        <Label styleClass="header-subtitle" text="Real-time capacity and updates" />
                                    </children>
                                </VBox>

                                <Region HBox.hgrow="ALWAYS" />

                                <!-- Right-side controls -->
                                <HBox alignment="CENTER" spacing="10.0">
                                    <children>

                                        <!-- Live pill -->
                                        <HBox alignment="CENTER" spacing="7.0" styleClass="status-pill">
                                            <padding>
                                                <Insets left="12.0" right="12.0" />
                                            </padding>
                                            <children>
                                                <Circle fill="#10b981" radius="4.0" styleClass="pulse-circle" />
                                                <Label styleClass="status-text" text="Live" />
                                            </children>
                                        </HBox>

                                        <!-- Login buttons -->
                                        <Button fx:id="btnBarangayLogin" mnemonicParsing="false" onAction="#handleBarangayLogin" styleClass="btn-outline" text="Barangay Login" />
                                        <Button fx:id="btnAdminLogin" mnemonicParsing="false" onAction="#handleAdminLogin" styleClass="btn-primary" text="Admin Login" />

                                        <!-- Refresh -->
                                        <Button mnemonicParsing="false" styleClass="btn-refresh" text="↻" />

                                    </children>
                                </HBox>

                            </children>
                        </HBox>
                        <!-- end header bar -->

                        <!-- ── BODY: Map card + Table ────────────────────── -->
                        <VBox spacing="20.0" styleClass="content-scroll" VBox.vgrow="ALWAYS">
                            <padding>
                                <Insets bottom="28.0" left="28.0" right="28.0" top="20.0" />
                            </padding>
                            <children>

                                <!-- ══ MAP CARD ══════════════════════════════ -->
                                <VBox styleClass="card-container" VBox.vgrow="ALWAYS">
                                    <children>

                                        <!-- Card header: title + search -->
                                        <VBox styleClass="card-header">
                                            <padding>
                                                <Insets bottom="12.0" left="18.0" right="18.0" top="16.0" />
                                            </padding>
                                            <children>
                                                <Label styleClass="card-title" text="Evacuation Center">
                                                    <padding>
                                                        <Insets bottom="10.0" />
                                                    </padding>
                                                </Label>

                                                <HBox alignment="CENTER_LEFT">
                                                    <children>
                                                        <TextField fx:id="searchField1" prefHeight="37.0" prefWidth="350.0" promptText="Search Evacuation Center..." styleClass="search-field" />

                                                        <Region HBox.hgrow="ALWAYS" />

                                                        <Button fx:id="btnHamburger" mnemonicParsing="false" onAction="#handleMenuClick" styleClass="btn-outline" text="⚡ Events" />
                                                    </children>
                                                </HBox>

                                            </children>
                                        </VBox>

                                        <!-- Map — full remaining height, no floating children -->
                                        <AnchorPane fx:id="mapOverlayPane" styleClass="map-overlay-pane" VBox.vgrow="ALWAYS">
                                            <children>
                                                <WebView fx:id="webViewMiniMap" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
                                            </children>
                                        </AnchorPane>

                                    </children>
                                </VBox>
                                <!-- end map card -->

                                <!-- ══ EVACUEE TABLE CARD ════════════════════ -->
                                <VBox styleClass="card-container" VBox.vgrow="NEVER">
                                    <children>

                                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="card-header">
                                            <padding>
                                                <Insets bottom="14.0" left="18.0" right="18.0" top="16.0" />
                                            </padding>
                                            <children>
                                                <Label styleClass="card-title" text="View Table" />
                                                <Region HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>

                                        <TableView fx:id="mainTable1" prefHeight="260.0" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colId1" prefWidth="90.0" text="ID" />
                                                <TableColumn fx:id="colName1" prefWidth="200.0" text="CENTER NAME" />
                                                <TableColumn fx:id="colCenter1" prefWidth="200.0" text="ADDRESS" />
                                                <TableColumn fx:id="colBarangay1" prefWidth="140.0" text="BARANGAY" />
                                                <TableColumn fx:id="colStatus1" prefWidth="110.0" text="STATUS" />
                                                <TableColumn fx:id="colAction1" prefWidth="90.0" text="CREATED AT" />
                                            </columns>
                                            <columnResizePolicy>
                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                            </columnResizePolicy>
                                        </TableView>

                                    </children>
                                </VBox>
                                <!-- end table card -->

                            </children>
                        </VBox>
                        <!-- end body -->

                    </children>
                </VBox>
                <!-- end main content -->

            </children>
        </HBox>
        <!-- end main layout HBox -->

        <!-- ══════════════════════════════════════════════════════════════
             EVENTS DRAWER  —  Direct child of root AnchorPane
             ──────────────────────────────────────────────────────────────
             Anchored to top / right / bottom so it sits flush against the
             right edge and covers the FULL height of the screen — including
             the header bar and the search field — when slid open.

             EventCellController.initialize() sets translateX = 300 so the
             panel starts completely off-screen. handleMenuClick() in
             KioskDashboardController calls eventCellController.toggleDrawer()
             to animate it in/out.

             mouseTransparent is false so the drawer receives clicks normally
             when open; when translated off-screen it is invisible AND
             unreachable, so no z-order tricks are needed.
             ══════════════════════════════════════════════════════════════ -->
        <fx:include fx:id="eventCell" source="EventCell.fxml" AnchorPane.bottomAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />

    </children>
</AnchorPane>
