<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.web.WebView?>

<!--
    BrgyUser.fxml — Public-facing Kiosk / Barangay Dashboard
    ──────────────────────────────────────────────────────────────────────
    Design system: "Trustworthy Municipal Tool"
    Palette  : Canvas #F7F5EE · Surface #FFFFFF · Border #E0D4BE
               Accent #5A6E4F · Danger #A0432F · Text #1C1917
    ──────────────────────────────────────────────────────────────────────
    Key structural changes vs. previous version:
      • alertsContainer (VBox, fx:id) is now exposed so the controller can
        dynamically populate and sort emergency alert cards.
      • mapOverlayPane hosts the WebView + the DetailModal overlay, which
        is loaded programmatically by KioskDashboardController.loadDetailModal().
      • All colours are resolved from style.css — no inline style attributes.
      • Layout uses VBox.vgrow / HBox.hgrow="ALWAYS" throughout so it fills
        the screen properly when the stage is maximised.
-->
<AnchorPane fx:id="mainRoot"
            prefHeight="800.0" prefWidth="1280.0"
            styleClass="root-pane"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.dashboard_kiosk.KioskDashboardController">
    <children>

        <!-- ── Outer shell: Sidebar + Main content ─────────────────────── -->
        <HBox AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              AnchorPane.topAnchor="0.0">
            <children>

                <!-- ══════════════════════════════════════════════════════
                     SIDEBAR
                     ══════════════════════════════════════════════════════ -->
                <VBox prefWidth="248.0" styleClass="sidebar" HBox.hgrow="NEVER">
                    <children>

                        <!-- Logotype -->
                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="logo-container">
                            <padding>
                                <Insets bottom="28.0" left="22.0" right="22.0" top="28.0" />
                            </padding>
                            <children>
                                <StackPane styleClass="logo-icon-bg">
                                    <children>
                                        <Label styleClass="logo-icon" text="CG" />
                                    </children>
                                </StackPane>
                                <Label styleClass="logo-text" text="CivicGuard" />
                            </children>
                        </HBox>

                        <!-- Navigation -->
                        <VBox spacing="4.0" VBox.vgrow="ALWAYS">
                            <padding>
                                <Insets left="14.0" right="14.0" top="8.0" />
                            </padding>
                            <children>
                                <Label styleClass="nav-header" text="PORTAL" />
                                <Button alignment="BASELINE_LEFT"
                                        maxWidth="1.7976931348623157E308"
                                        styleClass="nav-item"
                                        text="Admin Portal" />
                                <Button alignment="BASELINE_LEFT"
                                        maxWidth="1.7976931348623157E308"
                                        styleClass="nav-item"
                                        text="LGU Portal" />
                                <Button alignment="BASELINE_LEFT"
                                        maxWidth="1.7976931348623157E308"
                                        styleClass="nav-item, nav-active"
                                        text="Evacuee Portal" />
                            </children>
                        </VBox>

                        <Region VBox.vgrow="ALWAYS" />

                        <!-- Profile footer -->
                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="profile-section">
                            <padding>
                                <Insets bottom="22.0" left="22.0" right="22.0" top="22.0" />
                            </padding>
                            <children>
                                <Circle radius="17.0" styleClass="avatar-circle" />
                                <VBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label styleClass="profile-name" text="Public View" />
                                        <Label styleClass="profile-role" text="Read-only access" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- ══════════════════════════════════════════════════════
                     MAIN CONTENT  (header + scrollable body)
                     ══════════════════════════════════════════════════════ -->
                <VBox HBox.hgrow="ALWAYS">
                    <children>

                        <!-- ── Top header bar ─────────────────────────── -->
                        <HBox alignment="CENTER_LEFT"
                              prefHeight="72.0"
                              spacing="20.0"
                              styleClass="header-bar">
                            <padding>
                                <Insets left="30.0" right="30.0" />
                            </padding>
                            <children>
                                <VBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label styleClass="header-title" text="Evacuation Status" />
                                        <Label styleClass="header-subtitle"
                                               text="Real-time capacity and updates" />
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <HBox alignment="CENTER" spacing="14.0">
                                    <children>
                                        <HBox alignment="CENTER" spacing="7.0" styleClass="status-pill">
                                            <padding>
                                                <Insets left="12.0" right="12.0" />
                                            </padding>
                                            <children>
                                                <!-- Fill colour set here because JavaFX shape fill
                                                     cannot be bound to a CSS class variable -->
                                                <Circle fill="#5A6E4F" radius="4.0" styleClass="pulse-circle" />
                                                <Label styleClass="status-text" text="Live" />
                                            </children>
                                        </HBox>
                                        <Button mnemonicParsing="false"
                                                styleClass="btn-refresh"
                                                text="↻" />
                                    </children>
                                </HBox>
                            </children>
                        </HBox>

                        <!-- ── Scrollable body ────────────────────────── -->
                        <VBox spacing="20.0"
                              styleClass="content-scroll"
                              VBox.vgrow="ALWAYS">
                            <padding>
                                <Insets bottom="28.0" left="28.0" right="28.0" top="20.0" />
                            </padding>
                            <children>

                                <!-- ── Row 1: Map (left) + Alerts (right) ── -->
                                <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                                    <children>

                                        <!-- MAP CARD -->
                                        <VBox styleClass="card-container" HBox.hgrow="ALWAYS">
                                            <children>
                                                <HBox alignment="CENTER_LEFT" styleClass="card-header">
                                                    <padding>
                                                        <Insets bottom="14.0" left="18.0"
                                                                right="18.0" top="16.0" />
                                                    </padding>
                                                    <children>
                                                        <Label styleClass="card-title" text="Map Overview" />
                                                    </children>
                                                </HBox>

                                                <!--
                                                    mapOverlayPane is the AnchorPane that holds:
                                                      1. WebView (full-size, behind)
                                                      2. DetailModal VBox (loaded in code, bottom-left)
                                                    DO NOT add children here in FXML — the controller
                                                    injects the modal programmatically.
                                                -->
                                                <AnchorPane fx:id="mapOverlayPane"
                                                            styleClass="map-overlay-pane"
                                                            VBox.vgrow="ALWAYS">
                                                    <children>
                                                        <WebView fx:id="webViewMiniMap"
                                                                 AnchorPane.bottomAnchor="0.0"
                                                                 AnchorPane.leftAnchor="0.0"
                                                                 AnchorPane.rightAnchor="0.0"
                                                                 AnchorPane.topAnchor="0.0" />
                                                    </children>
                                                </AnchorPane>
                                            </children>
                                        </VBox>

                                        <!-- ALERTS CARD -->
                                        <VBox prefWidth="340.0"
                                              styleClass="card-container"
                                              HBox.hgrow="NEVER">
                                            <children>
                                                <HBox alignment="CENTER_LEFT" styleClass="card-header">
                                                    <padding>
                                                        <Insets bottom="14.0" left="18.0"
                                                                right="18.0" top="16.0" />
                                                    </padding>
                                                    <children>
                                                        <Label styleClass="card-title"
                                                               text="Emergency Alerts" />
                                                    </children>
                                                </HBox>

                                                <!--
                                                    alertsContainer is populated and sorted by the
                                                    controller (KioskDashboardController.setupAlerts()).
                                                    Newest alert appears first.
                                                -->
                                                <VBox fx:id="alertsContainer"
                                                      spacing="10.0"
                                                      VBox.vgrow="ALWAYS">
                                                    <padding>
                                                        <Insets bottom="18.0" left="18.0"
                                                                right="18.0" top="14.0" />
                                                    </padding>
                                                </VBox>

                                                <!-- Static footer note -->
                                                <Label style="-fx-font-size: 11; -fx-text-fill: #A8A29E;"
                                                       text="Call 911 for life-threatening emergencies."
                                                       wrapText="true">
                                                    <VBox.margin>
                                                        <Insets bottom="16.0" left="18.0" right="18.0" />
                                                    </VBox.margin>
                                                </Label>
                                            </children>
                                        </VBox>

                                    </children>
                                </HBox>

                                <!-- ── Row 2: Evacuation Centers Table ──── -->
                                <VBox styleClass="card-container" VBox.vgrow="ALWAYS">
                                    <children>
                                        <!-- Table header -->
                                        <HBox alignment="CENTER_LEFT"
                                              spacing="12.0"
                                              styleClass="card-header">
                                            <padding>
                                                <Insets bottom="14.0" left="18.0"
                                                        right="18.0" top="16.0" />
                                            </padding>
                                            <children>
                                                <Label styleClass="card-title"
                                                       text="Evacuation Centers" />
                                                <Region HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>

                                        <!-- Search + filter controls -->
                                        <HBox alignment="CENTER_LEFT"
                                              spacing="14.0"
                                              styleClass="table-controls">
                                            <padding>
                                                <Insets bottom="14.0" left="18.0"
                                                        right="18.0" top="14.0" />
                                            </padding>
                                            <children>
                                                <TextField fx:id="searchField1"
                                                           prefHeight="34.0"
                                                           prefWidth="240.0"
                                                           promptText="Search center or location…"
                                                           styleClass="search-field" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <HBox styleClass="segmented-control">
                                                    <children>
                                                        <Button fx:id="filterAll1"
                                                                mnemonicParsing="false"
                                                                styleClass="segment, segment-first, segment-active"
                                                                text="All" />
                                                        <Button fx:id="filterOpen1"
                                                                mnemonicParsing="false"
                                                                styleClass="segment"
                                                                text="Open" />
                                                        <Button fx:id="filterFull1"
                                                                mnemonicParsing="false"
                                                                styleClass="segment, segment-last"
                                                                text="Full" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </HBox>

                                        <!-- Data table -->
                                        <TableView fx:id="mainTable1"
                                                   prefHeight="240.0"
                                                   VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colId1"
                                                             prefWidth="200.0"
                                                             text="CENTER NAME" />
                                                <TableColumn fx:id="colName1"
                                                             prefWidth="280.0"
                                                             text="ADDRESS" />
                                                <TableColumn fx:id="colCenter1"
                                                             prefWidth="100.0"
                                                             text="STATUS" />
                                                <TableColumn fx:id="colStatus1"
                                                             prefWidth="160.0"
                                                             text="OCCUPANCY / ACTION" />
                                            </columns>
                                            <columnResizePolicy>
                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                            </columnResizePolicy>
                                        </TableView>
                                    </children>
                                </VBox>

                            </children>
                        </VBox>
                    </children>
                </VBox>

            </children>
        </HBox>
    </children>
</AnchorPane>
