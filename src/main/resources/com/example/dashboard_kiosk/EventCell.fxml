<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
    EventCell.fxml — Full-height Events Drawer (v2)
    ─────────────────────────────────────────────────
    • prefWidth="300" — fixed panel width.
    • EventCellController.initialize() sets translateX = prefWidth (300)
      so the panel is fully off-screen on load.
    • toggleDrawer() animates translateX between 300 (hidden) and 0 (visible).
    • Because this node is a direct child of the root AnchorPane (anchored
      top/right/bottom), it overlays the header, search field, map AND table
      when open — exactly the desired behaviour.
    • A close button (×) is placed in the drawer header for discoverability.
    • All colours defer to style.css via styleClass; no inline -fx- added.
    ─────────────────────────────────────────────────
-->

<VBox
        xmlns="http://javafx.com/javafx"
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="com.example.dashboard_kiosk.EventCellController"
        fx:id="eventCellRoot"
        prefWidth="300.0"
        maxWidth="300.0"
        styleClass="kiosk-event-cell">

    <children>

        <!-- ── Drawer header ───────────────────────────────────────────── -->
        <!--
            Full-width row: icon + title on the left, × close button on the right.
            Matches the card-header style used across the dashboard for consistency.
        -->
        <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="kiosk-event-header">
            <padding>
                <Insets bottom="14.0" left="18.0" right="12.0" top="14.0"/>
            </padding>
            <children>
                <Label styleClass="kiosk-event-title" text="⚡ Events"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button
                        fx:id="btnCloseDrawer"
                        mnemonicParsing="false"
                        onAction="#handleClose"
                        styleClass="btn-modal-close"
                        text="✕"/>
            </children>
        </HBox>

        <!-- ── Scrollable alert list ───────────────────────────────────── -->
        <ScrollPane
                fitToWidth="true"
                hbarPolicy="NEVER"
                vbarPolicy="AS_NEEDED"
                styleClass="kiosk-event-scroll"
                VBox.vgrow="ALWAYS">
            <content>
                <VBox fx:id="alertsContainer" spacing="10.0">
                    <padding>
                        <Insets bottom="18.0" left="14.0" right="14.0" top="10.0"/>
                    </padding>
                    <!-- Alert items are injected programmatically by EventCellController -->
                </VBox>
            </content>
        </ScrollPane>

    </children>
</VBox>
