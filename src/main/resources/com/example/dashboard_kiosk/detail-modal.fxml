<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
    detail-modal.fxml — Floating center detail overlay
    ───────────────────────────────────────────────────
    • Loaded programmatically by KioskDashboardController.loadDetailModal()
      and anchored to the bottom-left of mapOverlayPane.
    • Starts hidden (visible="false" managed="false").
    • Controller: com.example.dashboard_kiosk.DetailModalController
      (NOTE: changed from dashboard_barangay_v2 to dashboard_kiosk package)
    • Palette follows "Trustworthy Municipal Tool" design system.
-->
<VBox fx:id="modalRoot"
      maxWidth="370.0"
      prefWidth="350.0"
      spacing="12.0"
      styleClass="detail-modal"
      visible="false"
      managed="false"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.dashboard_kiosk.DetailModalController">
    <padding>
        <Insets bottom="18.0" left="20.0" right="20.0" top="18.0" />
    </padding>
    <children>

        <!-- ── HEADER: title · status pill · close ─────────────────── -->
        <HBox alignment="TOP_LEFT" spacing="8.0">
            <children>
                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label fx:id="lblTitle"
                               styleClass="detail-title"
                               text="Evacuation Center"
                               wrapText="true" />
                        <Label fx:id="lblMeta"
                               styleClass="detail-meta"
                               text="EC-00 · Brgy. —" />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <!-- Status pill — class toggled between status-tag-open and
                     status-tag-full by DetailModalController.show() -->
                <!-- Close button -->
                <Button fx:id="btnClose"
                        mnemonicParsing="false"
                        onAction="#handleClose"
                        styleClass="btn-modal-close"
                        text="✕" />
            </children>
        </HBox>

        <!-- ── ADDRESS ──────────────────────────────────────────────── -->
        <VBox spacing="3.0">
            <children>
                <Label styleClass="detail-section-label" text="ADDRESS" />
                <Label fx:id="lblAddress"
                       styleClass="detail-section-body"
                       text="—"
                       wrapText="true" />
            </children>
        </VBox>

        <!-- ── SUPPLIES ──────────────────────────────────────────────── -->
        <VBox spacing="5.0">
            <children>
                <Label styleClass="detail-section-label" text="SUPPLIES &amp; KITS" />
                <FlowPane fx:id="suppliesFlow"
                          hgap="6.0"
                          vgap="6.0"
                          styleClass="supplies-flow" />
            </children>
        </VBox>

        <!-- ── ACTION BUTTONS ────────────────────────────────────────── -->
        <HBox spacing="8.0">
            <children>
                <Button fx:id="btnShowRoute"
                        maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false"
                        onAction="#handleShowRoute"
                        styleClass="btn-primary"
                        text="Show Route"
                        HBox.hgrow="ALWAYS" />
                <Button fx:id="btnViewDetails"
                        maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false"
                        onAction="#handleViewDetails"
                        styleClass="btn-outline"
                        text="Full Details"
                        HBox.hgrow="ALWAYS" />
            </children>
        </HBox>

    </children>
</VBox>
