<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.dashboard_kiosk.controller.EventCellController"
      fx:id="eventCellRoot"
      prefWidth="300.0"
      maxWidth="300.0"
      styleClass="kiosk-event-cell">

    <children>

        <!-- Drawer header: title + close button -->
        <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="kiosk-event-header">
            <padding>
                <Insets bottom="14.0" left="18.0" right="12.0" top="14.0"/>
            </padding>
            <children>
                <Label styleClass="kiosk-event-title" text="⚡ Events"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnCloseDrawer"
                        mnemonicParsing="false"
                        onAction="#handleClose"
                        styleClass="btn-modal-close"
                        text="✕"/>
            </children>
        </HBox>

        <!-- Search field -->
        <VBox>
            <padding>
                <Insets left="14.0" right="14.0" top="14.0"/>
            </padding>
            <children>
                <TextField fx:id="searchField" promptText="🔍 Search location..." styleClass="search-field"/>
            </children>
        </VBox>

        <!-- Scrollable alert list -->
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    styleClass="kiosk-event-scroll"
                    VBox.vgrow="ALWAYS">
            <content>
                <VBox fx:id="alertsContainerVBox" spacing="10.0">
                    <padding>
                        <Insets bottom="18.0" left="14.0" right="14.0" top="10.0"/>
                    </padding>
                    <!-- Alert cards are inserted by EventCellController -->
                </VBox>
            </content>
        </ScrollPane>

    </children>
</VBox>
