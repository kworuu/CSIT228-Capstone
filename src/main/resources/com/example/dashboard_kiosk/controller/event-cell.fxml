<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="eventCellRoot" maxWidth="300.0" prefWidth="300.0" styleClass="kiosk-event-cell" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.dashboard_kiosk.controller.EventCellController">

    <children>

        <!-- Drawer header: title + close button -->
        <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="kiosk-event-header">
            <padding>
                <Insets bottom="14.0" left="18.0" right="12.0" top="14.0" />
            </padding>
            <children>
                <Label styleClass="kiosk-event-title" text="Events" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="btnCloseDrawer" mnemonicParsing="false" onAction="#handleClose" styleClass="btn-modal-close" text="✕" />
            </children>
        </HBox>

        <!-- Search field -->
        <VBox>
            <padding>
                <Insets left="14.0" right="14.0" top="14.0" />
            </padding>
            <children>
                <TextField fx:id="searchField" promptText="🔍 " styleClass="search-field" />
            </children>
        </VBox>

        <!-- Scrollable alert list -->
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="kiosk-event-scroll" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
            <content>
                <VBox fx:id="alertsContainerVBox" spacing="10.0">
                    <padding>
                        <Insets bottom="18.0" left="14.0" right="14.0" top="10.0" />
                    </padding>
                    <!-- Alert cards are inserted by EventCellController -->
                </VBox>
            </content>
        </ScrollPane>

    </children>
</VBox>
