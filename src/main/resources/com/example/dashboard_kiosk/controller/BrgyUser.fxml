<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.web.WebView?>

<AnchorPane fx:id="rootPane"
            prefHeight="800.0"
            prefWidth="1280.0"
            styleClass="root-pane"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.dashboard_kiosk.controller.KioskDashboardController">

    <children>
        <HBox AnchorPane.topAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0">
            <children>

                <!-- ══ SIDEBAR ═════════════════════════════════════════ -->
                <VBox prefWidth="230.0" styleClass="sidebar" HBox.hgrow="NEVER">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="logo-container">
                            <padding><Insets top="28.0" bottom="28.0" left="22.0" right="22.0"/></padding>
                            <children>
                                <StackPane styleClass="logo-icon-bg">
                                    <children>
                                        <Label styleClass="logo-icon" text="CG"/>
                                    </children>
                                </StackPane>
                                <Label styleClass="logo-text" text="CivicGuard"/>
                            </children>
                        </HBox>

                        <VBox spacing="4.0" VBox.vgrow="ALWAYS">
                            <padding><Insets top="8.0" left="14.0" right="14.0"/></padding>
                            <children>
                                <Label styleClass="nav-header" text="PORTAL"/>
                                <Button alignment="BASELINE_LEFT"
                                        maxWidth="1.7976931348623157E308"
                                        styleClass="nav-item, nav-active"
                                        text="🗺  Evacuee Portal"
                                        mnemonicParsing="false"/>
                            </children>
                        </VBox>

                        <Region VBox.vgrow="ALWAYS"/>

                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="profile-section">
                            <padding><Insets top="22.0" bottom="22.0" left="22.0" right="22.0"/></padding>
                            <children>
                                <Circle radius="17.0" styleClass="avatar-circle"/>
                                <VBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label styleClass="profile-name" text="Public View"/>
                                        <Label styleClass="profile-role" text="Read-only access"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- ══ MAIN COLUMN ═════════════════════════════════════ -->
                <VBox HBox.hgrow="ALWAYS">
                    <children>

                        <!-- ── HEADER BAR ─────────────────────────── -->
                        <HBox alignment="CENTER_LEFT"
                              prefHeight="64.0"
                              spacing="12.0"
                              styleClass="header-bar">
                            <padding><Insets left="28.0" right="28.0"/></padding>
                            <children>
                                <VBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label styleClass="header-title" text="Evacuation Status"/>
                                        <Label styleClass="header-subtitle"
                                               text="Real-time capacity · Live map view"/>
                                    </children>
                                </VBox>

                                <Region HBox.hgrow="ALWAYS"/>

                                <HBox alignment="CENTER" spacing="10.0">
                                    <children>
                                        <HBox alignment="CENTER" spacing="7.0" styleClass="status-pill">
                                            <padding><Insets left="12.0" right="12.0"/></padding>
                                            <children>
                                                <Circle fill="#10b981" radius="4.0" styleClass="pulse-circle"/>
                                                <Label styleClass="status-text" text="Live"/>
                                            </children>
                                        </HBox>

                                        <Button fx:id="btnBarangayLogin"
                                                mnemonicParsing="false"
                                                onAction="#handleBarangayLogin"
                                                styleClass="btn-outline"
                                                text="Barangay Login"/>
                                        <Button fx:id="btnAdminLogin"
                                                mnemonicParsing="false"
                                                onAction="#handleAdminLogin"
                                                styleClass="btn-primary"
                                                text="Admin Login"/>

                                        <Button mnemonicParsing="false"
                                                styleClass="btn-refresh"
                                                text="↻"/>
                                    </children>
                                </HBox>
                            </children>
                        </HBox>

                        <!-- ── MAP REGION + BOTTOM TABS ──────────── -->
                        <VBox VBox.vgrow="ALWAYS">
                            <children>

                                <!-- Full-bleed map layer -->
                                <StackPane VBox.vgrow="ALWAYS">
                                    <children>
                                        <WebView fx:id="miniMapWebView"
                                                 maxHeight="1.7976931348623157E308"
                                                 maxWidth="1.7976931348623157E308"/>

                                        <!-- Top-right overlay: search + events trigger -->
                                        <HBox alignment="CENTER_RIGHT"
                                              spacing="8.0"
                                              maxWidth="-Infinity"
                                              maxHeight="-Infinity"
                                              pickOnBounds="false"
                                              StackPane.alignment="TOP_RIGHT">
                                            <StackPane.margin><Insets top="16.0" right="16.0"/></StackPane.margin>
                                            <children>
                                                <TextField fx:id="searchField"
                                                           prefHeight="38.0"
                                                           prefWidth="260.0"
                                                           promptText="🔍  Search center…"
                                                           styleClass="search-field"/>
                                                <Button fx:id="btnEventsToggle"
                                                        mnemonicParsing="false"
                                                        onAction="#handleMenuClick"
                                                        styleClass="btn-outline"
                                                        text="⚡  Events"/>
                                            </children>
                                        </HBox>

                                        <!-- Floating bottom-left detail modal (loaded via fx:include)
                                             Margin is handled by translateX/translateY in the controller
                                             since StackPane.margin cannot be set on an fx:include root
                                             that is an AnchorPane in SceneBuilder. -->
                                        <fx:include fx:id="detailModal"
                                                    source="detail-modal.fxml"
                                                    StackPane.alignment="BOTTOM_LEFT"/>

                                    </children>
                                </StackPane>

                                <!-- Bottom TabPane
                                     tabClosingPolicy="ALL_TABS" allows dynamically-added
                                     roster tabs to be closed by the user. The two static
                                     tabs (Centers Overview, Evacuees) are protected from
                                     closing in code via tab.setClosable(false). -->
                                <TabPane fx:id="bottomTabPane"
                                         prefHeight="280.0"
                                         styleClass="card-container"
                                         tabClosingPolicy="ALL_TABS"
                                         VBox.vgrow="NEVER">
                                    <tabs>

                                        <!-- Centers Overview tab -->
                                        <Tab fx:id="tabCentersOverview" text="📍  Centers Overview">
                                            <content>
                                                <VBox>
                                                    <children>
                                                        <HBox alignment="CENTER_LEFT"
                                                              spacing="12.0"
                                                              styleClass="card-header">
                                                            <padding><Insets top="10.0" bottom="10.0" left="18.0" right="18.0"/></padding>
                                                            <children>
                                                                <Label styleClass="card-title"
                                                                       text="Evacuation Centers"/>
                                                                <Region HBox.hgrow="ALWAYS"/>
                                                                <Label styleClass="detail-meta"
                                                                       text="Live registry · all active centers"/>
                                                            </children>
                                                        </HBox>

                                                        <!-- colCenterId removed per read-only kiosk spec -->
                                                        <TableView fx:id="centerTableView"
                                                                   prefHeight="200.0"
                                                                   VBox.vgrow="ALWAYS">
                                                            <columns>
                                                                <TableColumn fx:id="colCenterName"
                                                                             prefWidth="220.0"
                                                                             text="CENTER NAME"/>
                                                                <TableColumn fx:id="colCenterAddress"
                                                                             prefWidth="200.0"
                                                                             text="ADDRESS"/>
                                                                <TableColumn fx:id="colCenterBarangay"
                                                                             prefWidth="150.0"
                                                                             text="BARANGAY"/>
                                                                <TableColumn fx:id="colCenterStatus"
                                                                             prefWidth="110.0"
                                                                             text="STATUS"/>
                                                                <TableColumn fx:id="colCenterCreatedAt"
                                                                             prefWidth="180.0"
                                                                             text="CREATED AT"/>
                                                            </columns>
                                                            <columnResizePolicy>
                                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                                            </columnResizePolicy>
                                                        </TableView>
                                                    </children>
                                                </VBox>
                                            </content>
                                        </Tab>

                                    </tabs>
                                </TabPane>

                            </children>
                        </VBox>

                    </children>
                </VBox>

            </children>
        </HBox>

        <!-- Right-edge events drawer (slides in from outside the viewport) -->
        <fx:include fx:id="eventCell"
                    source="EventCell.fxml"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.rightAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"/>

    </children>
</AnchorPane>
