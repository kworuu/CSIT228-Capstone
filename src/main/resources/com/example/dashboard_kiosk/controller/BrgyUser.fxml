<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<AnchorPane fx:id="rootPane" prefHeight="800.0" prefWidth="1280.0" styleClass="root-pane" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.dashboard_kiosk.controller.KioskDashboardController">

    <children>
        <HBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>

                <!-- ══ SIDEBAR ═════════════════════════════════════════ -->
                <VBox prefWidth="230.0" styleClass="sidebar" HBox.hgrow="NEVER">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="logo-container">
                            <padding><Insets bottom="28.0" left="22.0" right="22.0" top="28.0" /></padding>
                            <children>
                                <StackPane styleClass="logo-icon-bg">
                                    <children>
                                        <Label styleClass="logo-icon" text="CG" />
                                    </children>
                                </StackPane>
                                <Label styleClass="logo-text" text="CivicGuard" />
                            </children>
                        </HBox>

                        <VBox prefHeight="723.0" prefWidth="229.0" spacing="4.0" VBox.vgrow="ALWAYS">
                            <padding><Insets left="14.0" right="14.0" top="8.0" /></padding>
                            <children>
                                <Label styleClass="nav-header" text="PORTAL" />
                                <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="nav-item, nav-active" text="Evacuee Portal" />
                            </children>
                        </VBox>

                        <Region VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>

                <!-- ══ MAIN COLUMN ═════════════════════════════════════ -->
                <VBox HBox.hgrow="ALWAYS">
                    <children>

                        <!-- ── HEADER BAR ─────────────────────────── -->
                        <HBox alignment="CENTER_LEFT" prefHeight="67.0" prefWidth="1050.0" spacing="12.0" styleClass="header-bar">
                            <padding><Insets left="28.0" right="28.0" /></padding>
                            <children>
                                <VBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label styleClass="header-title" text="Evacuation Overview" />
                                        <Label styleClass="header-subtitle" text="Real-time overviews· Live map view" />
                                    </children>
                                </VBox>

                                <Region HBox.hgrow="ALWAYS" />

                                <HBox alignment="CENTER" spacing="10.0">
                                    <children>

                                        <Button fx:id="btnBarangayLogin" mnemonicParsing="false" onAction="#handleBarangayLogin" styleClass="btn-outline" text="Barangay Login" />
                                        <Button fx:id="btnAdminLogin" mnemonicParsing="false" onAction="#handleAdminLogin" styleClass="btn-primary" text="Admin Login" />

                                        <Button mnemonicParsing="false" styleClass="btn-refresh" text="↻" />
                                    </children>
                                </HBox>
                            </children>
                        </HBox>

                        <!-- ── MAP REGION + BOTTOM TABS ──────────── -->
                        <VBox VBox.vgrow="ALWAYS">
                            <children>

                                <!-- Full-bleed map layer -->
                                <StackPane VBox.vgrow="ALWAYS">
                                    <children>
                                        <WebView fx:id="miniMapWebView" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="431.0" prefWidth="1050.0" />

                                        <!-- Top-right overlay: search + events trigger -->
                                        <HBox alignment="CENTER_RIGHT" maxHeight="-Infinity" maxWidth="-Infinity" pickOnBounds="false" spacing="8.0" StackPane.alignment="TOP_RIGHT">
                                            <StackPane.margin><Insets right="16.0" top="16.0" /></StackPane.margin>
                                            <children>
                                                <TextField fx:id="searchField" prefHeight="38.0" prefWidth="260.0" promptText="🔍  " styleClass="search-field" />
                                                <Button fx:id="btnEventsToggle" mnemonicParsing="false" onAction="#handleMenuClick" styleClass="btn-outline" text="Events" />
                                            </children>
                                        </HBox>

                                        <!-- Floating bottom-left detail modal (loaded via fx:include)
                                             Margin is handled by translateX/translateY in the controller
                                             since StackPane.margin cannot be set on an fx:include root
                                             that is an AnchorPane in SceneBuilder. -->
                                        <fx:include fx:id="detailModal" source="detail-modal.fxml" StackPane.alignment="BOTTOM_LEFT" />

                                    </children>
                                </StackPane>

                                <!-- Bottom TabPane
                                     tabClosingPolicy="ALL_TABS" allows dynamically-added
                                     roster tabs to be closed by the user. The two static
                                     tabs (Centers Overview, Evacuees) are protected from
                                     closing in code via tab.setClosable(false). -->
                                <TabPane fx:id="bottomTabPane" prefHeight="280.0" styleClass="card-container" tabClosingPolicy="ALL_TABS" VBox.vgrow="NEVER">
                                    <tabs>

                                        <!-- Centers Overview tab -->
                                        <Tab fx:id="tabCentersOverview" text="📍  Centers Overview">
                                            <content>
                                                <VBox>
                                                    <children>
                                                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="card-header">
                                                            <padding><Insets bottom="10.0" left="18.0" right="18.0" top="10.0" /></padding>
                                                            <children>
                                                                <Label styleClass="card-title" text="Evacuation Centers" />
                                                                <Region HBox.hgrow="ALWAYS" />
                                                                <Label styleClass="detail-meta" text="Live registry · all active centers" />
                                                            </children>
                                                        </HBox>

                                                        <!-- colCenterId removed per read-only kiosk spec -->
                                                        <TableView fx:id="centerTableView" prefHeight="200.0" VBox.vgrow="ALWAYS">
                                                            <columns>
                                                                <TableColumn fx:id="colCenterName" prefWidth="220.0" text="CENTER NAME" />
                                                                <TableColumn fx:id="colCenterAddress" prefWidth="200.0" text="ADDRESS" />
                                                                <TableColumn fx:id="colCenterBarangay" prefWidth="150.0" text="BARANGAY" />
                                                                <TableColumn fx:id="colCenterStatus" prefWidth="110.0" text="STATUS" />
                                                                <TableColumn fx:id="colCenterCreatedAt" prefWidth="180.0" text="CREATED AT" />
                                                            </columns>
                                                            <columnResizePolicy>
                                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                                            </columnResizePolicy>
                                                        </TableView>
                                                    </children>
                                                </VBox>
                                            </content>
                                        </Tab>

                                    </tabs>
                                </TabPane>

                            </children>
                        </VBox>

                    </children>
                </VBox>

            </children>
        </HBox>

        <!-- Right-edge events drawer (slides in from outside the viewport) -->
        <fx:include fx:id="eventCell" source="EventCell.fxml" AnchorPane.bottomAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />

    </children>
</AnchorPane>
