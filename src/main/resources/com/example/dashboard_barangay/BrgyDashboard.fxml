<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.web.WebView?>

<AnchorPane
        fx:id="anchorPaneMainRoot"
        prefHeight="800.0"
        prefWidth="1280.0"
        styleClass="root-pane"
        stylesheets="@style.css"
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.example.dashboard_barangay.BrgyDashboardController">

    <children>

        <VBox
                fx:id="vboxSidebar"
                prefWidth="230.0"
                styleClass="brgy-sidebar"
                AnchorPane.bottomAnchor="0.0"
                AnchorPane.leftAnchor="0.0"
                AnchorPane.topAnchor="0.0">

            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="brgy-logo-row">
                    <padding><Insets bottom="28.0" left="20.0" right="20.0" top="28.0"/></padding>
                    <children>
                        <StackPane styleClass="brgy-logo-badge">
                            <children><Label text="CG" styleClass="brgy-logo-badge-text"/></children>
                        </StackPane>
                        <VBox alignment="CENTER_LEFT" spacing="1.0">
                            <children>
                                <Label text="CivicGuard" styleClass="brgy-logo-name"/>
                                <Label fx:id="labelBrgyName" text="Barangay Portal" styleClass="brgy-logo-sub"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <Label text="NAVIGATION" styleClass="brgy-nav-section-label">
                    <padding><Insets left="20.0" bottom="6.0"/></padding>
                </Label>

                <VBox spacing="4.0">
                    <padding><Insets left="12.0" right="12.0"/></padding>
                    <children>
                        <Button fx:id="buttonNavMap"
                                text="🗺  Map View"
                                maxWidth="1.7976931348623157E308"
                                mnemonicParsing="false"
                                styleClass="brgy-nav-btn, brgy-nav-active"
                                onAction="#handleNavMap"/>
                        <Button fx:id="buttonNavRegister"
                                text="📋  Registrations"
                                maxWidth="1.7976931348623157E308"
                                mnemonicParsing="false"
                                styleClass="brgy-nav-btn"
                                onAction="#handleNavRegister"/>
                        <Button fx:id="buttonNavActivity"
                                text="📜  Activity Log"
                                maxWidth="1.7976931348623157E308"
                                mnemonicParsing="false"
                                styleClass="brgy-nav-btn"
                                onAction="#handleNavActivity"/>
                        <Button text="📦 Request Supply"
                                onAction="#handleOpenSupplyRequests"
                                styleClass="brgy-btn-ghost"
                                maxWidth="1.7976931348623157E308"
                        />
                    </children>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <VBox styleClass="brgy-sidebar-status">
                    <padding><Insets left="20.0" right="20.0" bottom="16.0"/></padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Circle fx:id="circleStatusDot" radius="5.0" fill="#10b981"/>
                                <Label fx:id="labelSystemStatus" text="System Live" styleClass="brgy-status-text"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="brgy-profile-row">
                    <padding><Insets left="20.0" right="20.0" bottom="24.0" top="14.0"/></padding>
                    <children>
                        <Label styleClass="brgy-avatar" text="BS"/>
                        <VBox alignment="CENTER_LEFT" spacing="1.0">
                            <children>
                                <Label fx:id="labelStaffName" text="Brgy. Staff" styleClass="brgy-profile-name"/>
                                <Label fx:id="labelStaffRole" text="Response Officer" styleClass="brgy-profile-role"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>

        <HBox
                fx:id="hboxHeaderBar"
                alignment="CENTER_LEFT"
                prefHeight="64.0"
                spacing="16.0"
                styleClass="brgy-header"
                AnchorPane.leftAnchor="230.0"
                AnchorPane.rightAnchor="0.0"
                AnchorPane.topAnchor="0.0">
            <padding><Insets left="28.0" right="28.0"/></padding>
            <children>
                <VBox alignment="CENTER_LEFT">
                    <children>
                        <Label fx:id="labelHeaderTitle" text="Map View" styleClass="brgy-header-title"/>
                        <Label fx:id="labelHeaderSubtitle" text="Live evacuation center status" styleClass="brgy-header-sub"/>
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="buttonRefresh"
                        text="↻  Refresh"
                        mnemonicParsing="false"
                        styleClass="brgy-btn-ghost"
                        onAction="#handleRefresh"/>
                <Button fx:id="buttonLogout"
                        text="⎋  Log Out"
                        mnemonicParsing="false"
                        styleClass="brgy-btn-ghost"
                        onAction="#handleLogout"/>
            </children>
        </HBox>

        <VBox
                fx:id="vboxPanelMap"
                spacing="0.0"
                AnchorPane.leftAnchor="230.0"
                AnchorPane.rightAnchor="0.0"
                AnchorPane.topAnchor="64.0"
                AnchorPane.bottomAnchor="0.0">
            <children>

                <StackPane fx:id="stackPaneMapContainer" VBox.vgrow="ALWAYS">
                    <children>

                        <WebView fx:id="webViewMap" />

                        <!-- CHANGED VBox to AnchorPane for Absolute close button positioning -->
                        <AnchorPane fx:id="vboxMapOverlay"
                              maxWidth="340.0"
                              prefWidth="320.0"
                              styleClass="brgy-map-overlay"
                              visible="false"
                              managed="false"
                              StackPane.alignment="BOTTOM_LEFT">
                            <StackPane.margin><Insets bottom="16.0" left="16.0"/></StackPane.margin>
                            <children>
                                <VBox spacing="10.0"
                                      AnchorPane.topAnchor="0.0"
                                      AnchorPane.bottomAnchor="0.0"
                                      AnchorPane.leftAnchor="0.0"
                                      AnchorPane.rightAnchor="0.0">
                                      <padding><Insets bottom="16.0" left="18.0" right="18.0" top="16.0"/></padding>
                                      <children>
                                          <ImageView fx:id="imgOverlayCenter"
                                                     fitHeight="140.0" fitWidth="284.0"
                                                     preserveRatio="false"
                                                     styleClass="brgy-overlay-img"/>

                                          <VBox spacing="2.0">
                                              <children>
                                                  <Label fx:id="labelOverlayName" text="Center Name" styleClass="brgy-overlay-title" wrapText="true"/>
                                                  <Label fx:id="labelOverlayAddress" text="Address" styleClass="brgy-overlay-address" wrapText="true"/>
                                              </children>
                                              <padding><Insets right="20.0"/></padding>
                                          </VBox>

                                          <VBox fx:id="vboxOverlayItemsBox" spacing="6.0">
                                              <children>
                                                  <Label text="AVAILABLE SUPPLIES" styleClass="brgy-overlay-section-label"/>
                                                  <FlowPane fx:id="flowPaneOverlayPillsRow" hgap="6.0" vgap="6.0" prefWrapLength="290.0"/>
                                              </children>
                                          </VBox>

                                          <VBox spacing="4.0">
                                              <children>
                                                  <Label text="CURRENT EVENT" styleClass="brgy-overlay-section-label"/>
                                                  <Label fx:id="labelOverlayEvent" text="No active event" styleClass="brgy-overlay-event" wrapText="true"/>
                                              </children>
                                          </VBox>

                                          <Label fx:id="labelOverlayTimestamp" text="Updated: —" styleClass="brgy-overlay-ts"/>

                                          <Button fx:id="buttonUpdateCenter"
                                                  text="✏  Update Center Info"
                                                  maxWidth="1.7976931348623157E308"
                                                  mnemonicParsing="false"
                                                  styleClass="brgy-btn-primary"
                                                  onAction="#handleUpdateCenter"/>
                                      </children>
                                </VBox>
                                <!-- The floating close button! -->
                                <Button fx:id="buttonOverlayClose"
                                        text="✕"
                                        mnemonicParsing="false"
                                        styleClass="brgy-overlay-close"
                                        onAction="#handleOverlayClose"
                                        AnchorPane.topAnchor="15.0"
                                        AnchorPane.rightAnchor="15.0"/>
                            </children>
                        </AnchorPane>

                    </children>
                </StackPane>

                <VBox styleClass="brgy-cards-strip" prefHeight="220.0" VBox.vgrow="NEVER">
                    <padding><Insets top="12.0" bottom="12.0" left="20.0" right="20.0"/></padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <padding><Insets bottom="10.0"/></padding>
                            <children>
                                <Label text="EVACUATION CENTERS" styleClass="brgy-strip-header"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="labelCenterCount" text="0 centers" styleClass="brgy-strip-count"/>
                            </children>
                        </HBox>
                        <ScrollPane
                                fx:id="scrollPaneCenterCards"
                                fitToHeight="true"
                                hbarPolicy="AS_NEEDED"
                                vbarPolicy="NEVER"
                                styleClass="brgy-cards-scroll"
                                VBox.vgrow="ALWAYS">
                            <content>
                                <HBox fx:id="hboxCenterCardsRow" spacing="14.0" alignment="CENTER_LEFT">
                                    <padding><Insets bottom="4.0" top="4.0"/></padding>
                                </HBox>
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>

            </children>
        </VBox>

        <VBox
                fx:id="vboxPanelRegister"
                spacing="0.0"
                visible="false"
                managed="false"
                AnchorPane.leftAnchor="230.0"
                AnchorPane.rightAnchor="0.0"
                AnchorPane.topAnchor="64.0"
                AnchorPane.bottomAnchor="0.0">
            <padding><Insets bottom="28.0" left="28.0" right="28.0" top="20.0"/></padding>
            <children>

                <VBox styleClass="brgy-card" VBox.vgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="brgy-card-header">
                            <padding><Insets bottom="14.0" left="20.0" right="20.0" top="18.0"/></padding>
                            <children>
                                <Label text="Evacuee Registrations" styleClass="brgy-card-title"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button fx:id="buttonExportCsv"
                                        text="↓ Export CSV"
                                        mnemonicParsing="false"
                                        styleClass="brgy-btn-ghost"/>
                                <Button fx:id="buttonRegisterEvacuee"
                                        text="+ Register Evacuee"
                                        mnemonicParsing="false"
                                        styleClass="brgy-btn-primary"
                                        onAction="#handleRegisterEvacuee"/>
                            </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="brgy-table-controls">
                            <padding><Insets bottom="12.0" left="20.0" right="20.0"/></padding>
                            <children>
                                <TextField fx:id="textFieldSearchEvacuees"
                                           prefHeight="36.0"
                                           prefWidth="300.0"
                                           promptText="Search by name, barangay, or center…"
                                           styleClass="brgy-search"/>
                                <Region HBox.hgrow="ALWAYS"/>
                            </children>
                        </HBox>

                        <TableView fx:id="tableViewEvacuees" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="tableColumnEvacId"      prefWidth="90.0"  text="ID"/>
                                <TableColumn fx:id="tableColumnEvacName"    prefWidth="200.0" text="FULL NAME"/>
                                <TableColumn fx:id="tableColumnEvacCenter"  prefWidth="200.0" text="CENTER"/>
                                <TableColumn fx:id="tableColumnEvacBrgy"    prefWidth="140.0" text="BARANGAY"/>
                                <TableColumn fx:id="tableColumnEvacFamily"  prefWidth="100.0" text="FAMILY SIZE"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

            </children>
        </VBox>

        <VBox
                fx:id="vboxPanelActivity"
                spacing="0.0"
                visible="false"
                managed="false"
                AnchorPane.leftAnchor="230.0"
                AnchorPane.rightAnchor="0.0"
                AnchorPane.topAnchor="64.0"
                AnchorPane.bottomAnchor="0.0">
            <padding><Insets bottom="28.0" left="28.0" right="28.0" top="20.0"/></padding>
            <children>

                <VBox styleClass="brgy-card" VBox.vgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="brgy-card-header">
                            <padding><Insets bottom="14.0" left="20.0" right="20.0" top="18.0"/></padding>
                            <children>
                                <Label text="Activity Log" styleClass="brgy-card-title"/>
                                <Region HBox.hgrow="ALWAYS"/>
                            </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="brgy-table-controls">
                            <padding><Insets bottom="12.0" left="20.0" right="20.0"/></padding>
                            <children>
                                <TextField fx:id="textFieldSearchActivity"
                                           prefHeight="36.0"
                                           prefWidth="300.0"
                                           promptText="Search activity…"
                                           styleClass="brgy-search"/>
                                <Region HBox.hgrow="ALWAYS"/>
                            </children>
                        </HBox>

                        <TableView fx:id="tableViewActivity" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="tableColumnActTime"    prefWidth="160.0" text="TIMESTAMP"/>
                                <TableColumn fx:id="tableColumnActAction"  prefWidth="200.0" text="ACTION"/>
                                <TableColumn fx:id="tableColumnActTarget"  prefWidth="200.0" text="TARGET"/>
                                <TableColumn fx:id="tableColumnActCenter"  prefWidth="200.0" text="CENTER"/>
                                <TableColumn fx:id="tableColumnActBy"      prefWidth="160.0" text="PERFORMED BY"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

            </children>
        </VBox>

    </children>
</AnchorPane>