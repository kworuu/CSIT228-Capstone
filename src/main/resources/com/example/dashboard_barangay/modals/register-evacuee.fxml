<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="anchorPaneRoot" prefHeight="480.0" prefWidth="450.0"
            styleClass="brgy-slate-modal"
            stylesheets="@../../dashboard_barangay/style.css"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.dashboard_barangay.RegisterEvacueeController">

    <children>
        <VBox fx:id="vboxContainer" spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="24.0" left="28.0" right="28.0" top="24.0" />
            </padding>
            <children>

                <VBox fx:id="vboxHeader" spacing="4.0">
                    <padding><Insets right="40.0" /></padding>
                    <children>
                        <Label styleClass="brgy-slate-title" text="Register Evacuee" wrapText="true" />
                        <Label styleClass="brgy-slate-sub" text="Manual input from master list" wrapText="true" />
                    </children>
                </VBox>

                <VBox spacing="16.0" VBox.vgrow="ALWAYS">
                    <children>
                        <VBox spacing="8.0">
                            <children>
                                <Label styleClass="brgy-slate-section-label" text="Full Name" />
                                <TextField fx:id="textFieldName" prefHeight="40.0" promptText="e.g. Juan Dela Cruz" styleClass="brgy-slate-input" />
                            </children>
                        </VBox>

                        <VBox spacing="8.0">
                            <children>
                                <Label styleClass="brgy-slate-section-label" text="Evacuation Center" />
                                <ComboBox fx:id="comboBoxCenter" prefHeight="40.0" prefWidth="400.0" promptText="Select center" styleClass="brgy-slate-input" />
                            </children>
                        </VBox>

                        <HBox spacing="16.0">
                            <children>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="brgy-slate-section-label" text="Contact Number (Optional)" />
                                        <TextField fx:id="textFieldContact" prefHeight="40.0" promptText="e.g. 09123456789" styleClass="brgy-slate-input" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <Label fx:id="labelError" textFill="#dc2626" visible="false" />
                    </children>
                </VBox>

                <HBox alignment="CENTER_RIGHT" spacing="12.0">
                    <children>
                        <Button fx:id="buttonRegister" onAction="#handleRegister" styleClass="brgy-btn-primary" text="Register" />
                    </children>
                </HBox>
            </children>
        </VBox>

        <Button fx:id="buttonCancel" onAction="#handleCancel" styleClass="brgy-slate-btn-close" text="✕" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0" />
    </children>
</AnchorPane>