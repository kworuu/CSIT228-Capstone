<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.web.WebView?>

<VBox alignment="CENTER" prefWidth="550.0" spacing="20.0" styleClass="brgy-slate-modal" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.dashboard_barangay.AddBrgyExtensionController">
    <children>
        <VBox prefWidth="520.0" spacing="25.0">
            <children>
                <!-- Header Section -->
                <VBox spacing="5.0">
                    <children>
                        <Label styleClass="brgy-slate-title" text="Evacuation Center Registration">
                            <font>
                                <Font name="Segoe UI Bold" size="24.0" />
                            </font>
                        </Label>
                        <Label styleClass="brgy-slate-sub" text="Register a new center by providing the details and location below." />
                    </children>
                </VBox>

                  <!-- Map Integration Layout -->
                  <VBox spacing="8.0">
                      <children>
                          <Label styleClass="brgy-slate-section-label" text="LOCATION SELECTION (MAP)" />
                          <TextField fx:id="mapSearchField" promptText="Search location on map..." styleClass="brgy-slate-input" visible="false" managed="false" />
                          <!-- Actual WebView for the Map -->
                          <WebView fx:id="extensionWebViewMap" prefHeight="200.0" style="-fx-background-color: #0f172a; -fx-border-color: #1e293b; -fx-border-radius: 5;" />
                      </children>
                  </VBox>

                <!-- Action Buttons -->
                <HBox spacing="15.0">
                    <children>
                        <Button fx:id="btnSaveLoc" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleConfirmLocation" prefHeight="45.0" styleClass="brgy-btn-primary" text="Save Location" HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnCancelLoc" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleCancelLocation" prefHeight="45.0" styleClass="brgy-slate-btn-ghost" text="Cancel" HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets bottom="30.0" left="35.0" right="35.0" top="30.0" />
            </padding>
        </VBox>
    </children>
</VBox>
