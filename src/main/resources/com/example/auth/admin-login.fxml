<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    AdminLogin.fxml — Admin authentication screen
    ─────────────────────────────────────────────
    Reuses the kiosk's style.css for consistency. Centered card layout
    with a subtle accent header. The "Back to Kiosk" button returns the
    user to the default landing screen via Router.navigate(KIOSK).
-->

<StackPane styleClass="root-pane"
           stylesheets="@../dashboard_kiosk/style.css"
           xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.auth.AdminLoginController">

    <VBox alignment="CENTER" spacing="20.0" maxWidth="420.0">
        <padding>
            <Insets top="40.0" right="40.0" bottom="40.0" left="40.0"/>
        </padding>

        <!-- Logo / brand mark -->
        <StackPane styleClass="logo-icon-bg" prefWidth="56" prefHeight="56" maxWidth="56" maxHeight="56">
            <Label styleClass="logo-icon" text="CG"/>
        </StackPane>

        <VBox alignment="CENTER" spacing="4.0">
            <Label styleClass="header-title" text="Admin Sign-In"/>
            <Label styleClass="header-subtitle" text="CivicGuard Disaster Response · Restricted Access"/>
        </VBox>

        <!-- Login card -->
        <VBox styleClass="card-container" spacing="16.0" maxWidth="420.0">
            <padding>
                <Insets top="28.0" right="32.0" bottom="28.0" left="32.0"/>
            </padding>

            <VBox spacing="6.0">
                <Label styleClass="nav-header" text="USERNAME"/>
                <TextField fx:id="usernameField"
                           promptText="admin"
                           styleClass="search-field"
                           prefHeight="38.0"/>
            </VBox>

            <VBox spacing="6.0">
                <Label styleClass="nav-header" text="PASSWORD"/>
                <PasswordField fx:id="passwordField"
                               promptText="••••••••"
                               styleClass="search-field"
                               prefHeight="38.0"
                               onAction="#handleLogin"/>
            </VBox>

            <!-- Error banner — hidden until login fails -->
            <Label fx:id="errorLabel"
                   styleClass="status-tag, status-tag-full"
                   text=""
                   visible="false"
                   managed="false"
                   maxWidth="Infinity"
                   wrapText="true"/>

            <Button fx:id="loginButton"
                    text="Sign In"
                    onAction="#handleLogin"
                    styleClass="btn-primary"
                    maxWidth="Infinity"
                    prefHeight="42.0"/>

            <Button text="← Back to Kiosk"
                    onAction="#handleBack"
                    styleClass="btn-outline"
                    maxWidth="Infinity"
                    prefHeight="38.0"/>
        </VBox>

        <Label text="Default test credentials: admin / changeme123"
               style="-fx-font-size: 11; -fx-text-fill: #A8A29E;"/>
    </VBox>
</StackPane>
