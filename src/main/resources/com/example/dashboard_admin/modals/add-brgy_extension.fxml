<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefWidth="550.0" spacing="20.0" styleClass="modal-overlay" stylesheets="@modalStyle.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.dashboard_admin.views.DashboardController">
    <children>
        <VBox prefWidth="520.0" spacing="25.0" styleClass="card-container">
            <children>
                <!-- Header Section -->
                <VBox spacing="5.0">
                    <children>
                        <Label styleClass="modal-title" text="Evacuation Center Registration">
                            <font>
                                <Font name="Segoe UI Bold" size="24.0" />
                            </font>
                        </Label>
                        <Label styleClass="modal-description" text="Register a new center by providing the details and location below." />
                    </children>
                </VBox>

                  <!-- Map Integration Layout -->
                  <VBox spacing="8.0">
                      <children>
                          <Label styleClass="field-label" text="LOCATION SELECTION (MAP)" />
                          <TextField fx:id="mapSearchField" promptText="Search location on map..." styleClass="search-field" />
                          <!-- Placeholder for the Map -->
                          <StackPane fx:id="mapContainer" prefHeight="200.0" style="-fx-background-color: #f0f0f0; -fx-border-color: #ddd; -fx-border-radius: 5;" styleClass="map-placeholder">
                              <children>
                                  <Label text="Map View Area" textFill="#999999" />
                              </children>
                          </StackPane>
                      </children>
                  </VBox>
      
                <!-- Action Buttons -->
                <HBox spacing="15.0">
                    <children>
                        <Button fx:id="btnSaveLoc" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="45.0" styleClass="btn-primary" text="Save Location" HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnCancel" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="45.0" styleClass="btn-outline" text="Cancel" HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets bottom="30.0" left="35.0" right="35.0" top="30.0" />
            </padding>
        </VBox>
    </children>
</VBox>
