<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<AnchorPane fx:id="mainRoot" prefHeight="800.0" prefWidth="1280.0" styleClass="root-pane" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.dashboard_admin.InventoryController">
    <children>
        <!-- SIDEBAR -->
        <VBox fx:id="sidebar" prefWidth="250.0" styleClass="sidebar" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="logo-container">
                    <children>
                        <StackPane styleClass="logo-icon-bg">
                            <children>
                                <Label styleClass="logo-icon" text="CG" />
                            </children>
                        </StackPane>
                        <Label styleClass="logo-text" text="CivicGuard" />
                    </children>
                    <padding>
                        <Insets bottom="40.0" left="24.0" right="24.0" top="32.0" />
                    </padding>
                </HBox>

                <VBox spacing="4.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Label styleClass="nav-header" text="OPERATIONS" />
                        <Button fx:id="navEvacuations" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="nav-item" text="Evacuations" />
                        <Button fx:id="navInventory" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="nav-item, nav-active" text="Inventory" />
                        <Button fx:id="navMap" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="nav-item" text="Map View" />
                    </children>
                    <padding>
                        <Insets left="12.0" right="12.0" />
                    </padding>
                </VBox>

                <!-- Profile Section -->
                <VBox styleClass="profile-section">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <Label alignment="CENTER" prefHeight="40.0" prefWidth="40.0" styleClass="avatar-circle" text="AD" />
                                <VBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label fx:id="lblUserName" styleClass="profile-name" text="Admin" />
                                        <Label fx:id="lblUserRole" styleClass="profile-role" text="Administrator" />
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <Button minWidth="24.0" mnemonicParsing="false" styleClass="btn-icon-soft" text="⋮" />
                            </children>
                        </HBox>
                    </children>
                    <padding>
                        <Insets bottom="24.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </VBox>
            </children>
        </VBox>

        <!-- MAIN LAYOUT -->
        <VBox layoutX="250.0" prefHeight="800.0" prefWidth="1030.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="250.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <!-- TOP HEADER -->
                <HBox alignment="CENTER_LEFT" prefHeight="72.0" spacing="20.0" styleClass="header-bar">
                    <children>
                        <VBox alignment="CENTER_LEFT">
                            <children>
                                <Label fx:id="headerTitle" styleClass="header-title" text="Response Operations" />
                                <Label styleClass="header-subtitle" text="Real-time monitoring for Tuesday, April 28" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER" spacing="16.0">
                            <children>
                                <HBox alignment="CENTER" spacing="8.0" styleClass="status-pill">
                                    <children>
                                        <Circle fill="#10b981" radius="4.0" styleClass="pulse-circle" />
                                        <Label fx:id="lblStatus" styleClass="status-text" text="System Live" />
                                    </children>
                                    <padding>
                                        <Insets left="12.0" right="12.0" />
                                    </padding>
                                </HBox>
                                <Button fx:id="btnRefresh" mnemonicParsing="false" styleClass="btn-refresh" text="↻" />
                            </children>
                        </HBox>
                    </children>
                    <padding>
                        <Insets left="32.0" right="32.0" />
                    </padding>
                </HBox>

                <!-- CONTENT AREA -->
                <VBox spacing="24.0" styleClass="content-scroll" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="32.0" left="32.0" right="32.0" top="24.0" />
                    </padding>
                    <children>
                        <!-- STAT CARDS -->
                        <HBox spacing="20.0" />

                        <!-- DATA TABLE SECTION -->
                        <VBox styleClass="card-container" VBox.vgrow="ALWAYS">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="card-header">
                                    <children>
                                        <Label styleClass="card-title" text="Item Registration" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button fx:id="btnNewItem" mnemonicParsing="false" styleClass="btn-primary" text="+ Insert Item" />
                                    </children>
                                    <padding>
                                        <Insets bottom="16.0" left="20.0" right="20.0" top="20.0" />
                                    </padding>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="table-controls">
                                    <children>
                                        <TextField fx:id="searchItemField" prefHeight="38.0" prefWidth="350.0" promptText="Search Item" styleClass="search-field" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <HBox styleClass="segmented-control">
                                            <children>
                                                <Button fx:id="filterAll" mnemonicParsing="false" styleClass="segment, segment-first, segment-active" text="All" />
                                                <Button fx:id="filterVerified" mnemonicParsing="false" styleClass="segment" text="Critical" />
                                                <Button fx:id="filterPending" mnemonicParsing="false" styleClass="segment, segment-last" text="Low" />
                                            </children>
                                        </HBox>
                                    </children>
                                    <padding>
                                        <Insets bottom="16.0" left="20.0" right="20.0" />
                                    </padding>
                                </HBox>

                                <TableView fx:id="mainTable" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colItemName" prefWidth="100.0" text="NAME" />
                                        <TableColumn fx:id="colCategory" prefWidth="200.0" text="CATEGORY" />
                                        <TableColumn fx:id="colUnit" prefWidth="220.0" text="UNIT" />
                                        <TableColumn fx:id="colStatus" prefWidth="160.0" text="STATUS" />
                              <TableColumn fx:id="colAction" prefWidth="160.0" text="ACTION" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
