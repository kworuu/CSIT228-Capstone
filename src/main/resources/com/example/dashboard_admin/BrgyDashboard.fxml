<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>

<AnchorPane fx:id="mainRoot" prefHeight="800.0" prefWidth="1280.0" styleClass="root-pane" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.dashboard_admin.DashboardController">
    <children>
      <HBox alignment="CENTER_LEFT" layoutX="10.0" layoutY="10.0">
         <children>
      
                          <!-- MAIN LAYOUT -->
              <VBox prefHeight="800.0" prefWidth="1270.0">
                  <children>
                      <!-- TOP HEADER -->
                      <HBox alignment="CENTER_LEFT" prefHeight="105.0" prefWidth="833.0" spacing="20.0" styleClass="header-bar">
                          <children>
                            <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="logo-container">
                                <children>
                                    <StackPane styleClass="logo-icon-bg">
                                        <children>
                                            <Label styleClass="logo-icon" text="CG" />
                                        </children>
                                    </StackPane>
                                    <Label styleClass="logo-text" text="CivicGuard" />
                                </children>
                                <padding>
                                    <Insets bottom="40.0" left="24.0" right="24.0" top="32.0" />
                                </padding>
                            </HBox>
                              <VBox alignment="CENTER_LEFT">
                                  <children>
                                      <Label fx:id="headerTitle" styleClass="header-title" text="Response Operations" />
                                      <Label styleClass="header-subtitle" text="Real-time monitoring for Tuesday, April 28" />
                                  </children>
                              </VBox>
                              <Region HBox.hgrow="ALWAYS" />
                              <HBox alignment="CENTER" spacing="16.0">
                                  <children>
                                      <HBox alignment="CENTER" spacing="8.0" styleClass="status-pill">
                                          <children>
                                              <Circle fill="#10b981" radius="4.0" styleClass="pulse-circle" />
                                              <Label fx:id="lblStatus" styleClass="status-text" text="System Live" />
                                          </children>
                                          <padding>
                                              <Insets left="12.0" right="12.0" />
                                          </padding>
                                      </HBox>
                                      <Button fx:id="btnRefresh" mnemonicParsing="false" styleClass="btn-refresh" text="↻" />
                                  </children>
                              </HBox>
                          </children>
                          <padding>
                              <Insets left="32.0" right="32.0" />
                          </padding>
                      </HBox>
                  <HBox prefHeight="713.0" prefWidth="1270.0">
                     <children>
                        <Region prefHeight="695.0" prefWidth="158.0" />
                        <VBox prefHeight="695.0" prefWidth="499.0">
                           <children>
                              <Region prefHeight="22.0" prefWidth="388.0" />
                              <VBox prefHeight="646.0" prefWidth="388.0" styleClass="card-container">
                                 <children>
                                    <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="card-header">
                                       <children>
                                          <Label styleClass="card-title" text="Recent Registrations" />
                                          <Region HBox.hgrow="ALWAYS" />
                                          <Button fx:id="btnNewEntry1" mnemonicParsing="false" styleClass="btn-primary" text="+ New Request" />
                                       </children>
                                       <padding>
                                          <Insets bottom="16.0" left="20.0" right="20.0" top="20.0" />
                                       </padding>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="table-controls">
                                       <children>
                                          <TextField fx:id="searchField1" prefHeight="36.0" prefWidth="103.0" promptText="Filter by name, center, or ID..." styleClass="search-field" />
                                          <Region HBox.hgrow="ALWAYS" />
                                          <HBox styleClass="segmented-control">
                                             <children>
                                                <Button fx:id="filterAll1" mnemonicParsing="false" styleClass="segment, segment-first, segment-active" text="All" />
                                                <Button fx:id="filterVerified1" mnemonicParsing="false" styleClass="segment" text="Verified" />
                                                <Button fx:id="filterPending1" mnemonicParsing="false" styleClass="segment, segment-last" text="Pending" />
                                             </children>
                                          </HBox>
                                       </children>
                                       <padding>
                                          <Insets bottom="16.0" left="20.0" right="20.0" />
                                       </padding>
                                    </HBox>
                                    <TableView fx:id="mainTable1" prefHeight="568.0" prefWidth="354.0" VBox.vgrow="ALWAYS">
                                       <columns>
                                          <TableColumn fx:id="colId1" prefWidth="94.0" text="NAME" />
                                          <TableColumn fx:id="colName1" prefWidth="87.0" text="QUANTITY" />
                                          <TableColumn fx:id="colCenter1" prefWidth="220.0" text="STATUS" />
                                          <TableColumn fx:id="colStatus1" prefWidth="120.0" text="ACTION" />
                                       </columns>
                                       <columnResizePolicy>
                                          <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                       </columnResizePolicy>
                                    </TableView>
                                 </children>
                              </VBox>
                           </children>
                        </VBox>
            
                                        <!-- CONTENT AREA -->
                            <VBox prefHeight="695.0" prefWidth="992.0" spacing="24.0" styleClass="content-scroll">
                                <padding>
                                    <Insets bottom="32.0" left="32.0" right="32.0" top="24.0" />
                                </padding>
                                <children>
                                    <!-- STAT CARDS -->
                                    <HBox spacing="20.0">
                                        <children>
                                            <VBox prefHeight="126.0" prefWidth="682.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                                <children>
                                          <Label styleClass="card-title" text="Activity Logs" />
                                          <Region prefHeight="12.0" prefWidth="768.0" />
                                          <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Text" />
                                                </children>
                                            </VBox>
                                        </children>
                                    </HBox>
            

                                    <VBox styleClass="card-container" VBox.vgrow="ALWAYS">
                                        <children>
                                            <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="card-header">
                                                <children>
                                                    <Label styleClass="card-title" text="Barangay View" />
                                                    <Region HBox.hgrow="ALWAYS" />
                                                </children>
                                                <padding>
                                                    <Insets bottom="16.0" left="20.0" right="20.0" top="20.0" />
                                                </padding>
                                            </HBox>
            
                                                        <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="table-controls">
                                                <children>
                                                    <Region HBox.hgrow="ALWAYS" />
                                                    <HBox styleClass="segmented-control" />
                                                </children>
                                                <padding>
                                                    <Insets bottom="16.0" left="20.0" right="20.0" />
                                                </padding>
                                            </HBox>
                                        </children>
                                    </VBox>
                                </children>
                            </VBox>
                     </children>
                  </HBox>
                  </children>
              </VBox>
         </children>
      </HBox>
    </children>
</AnchorPane>
